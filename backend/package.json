{
  "name": "groove-backend",
  "version": "1.0.0",
  "description": "API REST (Express + Prisma) para la tienda de música Groove",
  "type": "module",
  "main": "src/app.js",
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "build": "prisma generate",
    "start": "node start.js",
    "dev": "node start.js",
    "db:migrate": "prisma migrate deploy",
    "db:seed": "node prisma/seed.js",
    "test": "node --test tests/*.test.js",
    "test:smoke": "node --test tests/health.test.js"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  },
  "dependencies": {
    "@prisma/client": "^6.19.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.0.0",
    "express": "^4.18.0",
    "express-rate-limit": "^8.2.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.0",
    "multer": "^1.4.5-lts.1"
  },
  "devDependencies": {
    "prisma": "^6.19.0",
    "jest": "^29.7.0",
    "supertest": "^6.3.3"
  }
}
